---
import '../styles/global.css';
interface Props {
  title?: string;
  description?: string;
  image?: string;
}
const { title = 'WEUX Content Finder | Find WordPress content and open the right editor', description = 'Search across posts, pages, custom post types, templates, patterns, navigation, Elementor data, and ACF fields from one WordPress admin screen.', image = '/og-image.png' } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const siteUrl = 'https://contentfinderwp.com/';

// --- Structured Data ---

const webSiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "WEUX Content Finder",
  "url": siteUrl,
  "description": "Find text across WordPress posts, pages, custom post types, templates, patterns, navigation, Elementor data, and ACF fields. Open the matching edit screen from each result.",
  "applicationCategory": "WordPress Plugin",
  "operatingSystem": "WordPress 6.0+"
};

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "WEUX Content Finder",
  "operatingSystem": "WordPress 6.0+",
  "applicationCategory": "Plugin",
  "offers": [
    { "@type": "Offer", "name": "Free", "price": "0", "priceCurrency": "EUR", "priceValidUntil": "2030-12-31" },
    { "@type": "Offer", "name": "Single Site", "price": "39", "priceCurrency": "EUR", "priceValidUntil": "2030-12-31" },
    { "@type": "Offer", "name": "5 Sites", "price": "79", "priceCurrency": "EUR", "priceValidUntil": "2030-12-31" },
    { "@type": "Offer", "name": "Unlimited", "price": "149", "priceCurrency": "EUR", "priceValidUntil": "2030-12-31" }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What does the free plugin do?", "acceptedAnswer": { "@type": "Answer", "text": "Free helps you find where content is managed across posts, pages, custom post types, templates, patterns, navigation, block theme files, Elementor data, and supported ACF matches. Results include editor links when WordPress provides them." } },
    { "@type": "Question", "name": "What does Pro add?", "acceptedAnswer": { "@type": "Answer", "text": "Pro adds Search and Replace with review, selected item replacement, before and after snippets, supported ACF field replacement, batch undo, replace history, and the global Cmd+K overlay." } },
    { "@type": "Question", "name": "Does search leave my WordPress site?", "acceptedAnswer": { "@type": "Answer", "text": "Free search runs inside your WordPress site and does not require an external search service. License requests only happen when a Pro license key is submitted." } },
    { "@type": "Question", "name": "Does it work with Elementor?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. WEUX Content Finder can search Elementor page data and show Edit in Elementor links when Elementor data and editor targets are available." } },
    { "@type": "Question", "name": "How does ACF support work?", "acceptedAnswer": { "@type": "Answer", "text": "Free can show ACF match counts without exposing field values. Pro adds search and replace for supported ACF text fields." } },
    { "@type": "Question", "name": "Is Search and Replace safe?", "acceptedAnswer": { "@type": "Answer", "text": "Pro starts with a review step. You preview replacements, read before and after snippets, choose the items to update, and confirmed jobs store snapshots for batch undo." } },
    { "@type": "Question", "name": "Is this a database migration tool?", "acceptedAnswer": { "@type": "Answer", "text": "No. WEUX Content Finder is made for WordPress editing screens, not database migrations or serialized data replacement. It locates editable content and updates supported content layers." } },
    { "@type": "Question", "name": "How much does Pro cost?", "acceptedAnswer": { "@type": "Answer", "text": "Pro licenses are handled via Lemon Squeezy: Single Site is €39/year, 5 Sites is €79/year, and Unlimited is €149/year." } }
  ]
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Canonical -->
    <link rel="canonical" href={siteUrl} />

    <!-- Icons & Favicons -->
    <link rel="icon" href={`${baseUrl}favicon.ico`} sizes="any" />
    <link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
    <link rel="icon" type="image/png" sizes="32x32" href={`${baseUrl}favicon-32x32.png`} />
    <link rel="icon" type="image/png" sizes="16x16" href={`${baseUrl}favicon-16x16.png`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`${baseUrl}apple-touch-icon.png`} />
    <link rel="manifest" href={`${baseUrl}site.webmanifest`} />
    <link rel="mask-icon" href={`${baseUrl}safari-pinned-tab.svg`} color="#2563EB" />
    <meta name="msapplication-TileColor" content="#2563EB" />
    <meta name="msapplication-TileImage" content={`${baseUrl}mstile-150x150.png`} />
    <meta name="theme-color" content="#2563EB" />

    <!-- Fonts -->
    <!-- Self-hosted via global.css -->

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`https://contentfinderwp.com${image}`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`https://contentfinderwp.com${image}`} />

    <!-- Structured Data: WebSite -->
    <script type="application/ld+json" data-schema="website">{JSON.stringify(webSiteSchema)}</script>

    <!-- Structured Data: SoftwareApplication -->
    <script type="application/ld+json" data-schema="software">{JSON.stringify(softwareSchema)}</script>

    <!-- Structured Data: FAQPage -->
    <script type="application/ld+json" data-schema="faq">{JSON.stringify(faqSchema)}</script>

    <!-- Matomo -->
    <script is:inline>
      var _paq = window._paq = window._paq || [];
      _paq.push(['trackPageView']);
      _paq.push(['enableLinkTracking']);
      (function() {
        var u = '//analyse.marcweidemueller.de/';
        _paq.push(['setTrackerUrl', u + 'matomo.php']);
        _paq.push(['setSiteId', '2']);
        var d = document;
        var g = d.createElement('script');
        var s = d.getElementsByTagName('script')[0];
        g.async = true;
        g.src = u + 'matomo.js';
        s.parentNode.insertBefore(g, s);
      })();
    </script>
    <!-- End Matomo Code -->
  </head>
  <body class="font-sans text-gray-900 antialiased bg-white">
    <slot />
    <script>
      document.querySelectorAll('.protected-contact[data-contact-value]').forEach((item) => {
        const encoded = item.getAttribute('data-contact-value');
        const kind = item.getAttribute('data-contact-kind');
        if (!encoded) return;

        try {
          const value = atob(encoded);
          item.textContent = value;

          if (item instanceof HTMLAnchorElement && kind === 'email') {
            item.href = `mailto:${value}`;
          }

          if (item instanceof HTMLAnchorElement && kind === 'phone') {
            item.href = `tel:${value.replace(/\s+/g, '')}`;
          }
        } catch {
          item.textContent = 'Contact details unavailable';
        }
      });
    </script>
  </body>
</html>
