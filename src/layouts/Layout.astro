---
import '../styles/global.css';
interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalPath?: string;
  canonicalUrl?: string;
  robots?: string;
  socialTitle?: string;
  includeProductSchema?: boolean;
}
const {
  title = 'WEUX Content Finder | Find WordPress content and open the right editor',
  description = 'Search across posts, pages, custom post types, templates, patterns, navigation, Elementor data, and ACF fields from one WordPress admin screen.',
  image = '/og-image.png',
  canonicalPath = '/',
  canonicalUrl,
  robots,
  socialTitle,
  includeProductSchema = false,
} = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const siteUrl = 'https://contentfinderwp.com/';
const canonicalHref = canonicalUrl ?? new URL(canonicalPath, siteUrl).href;
const socialMetaTitle = socialTitle ?? title;
const wordpressPluginUrl = 'https://wordpress.org/plugins/weux-content-finder/';
const studioUrl = 'https://weux.studio/';
const dateModified = '2026-06-23';

// --- Structured Data ---

const webSiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "WEUX Content Finder",
  "url": siteUrl,
  "description": "Find text across WordPress posts, pages, custom post types, templates, patterns, navigation, Elementor data, and ACF fields. Open the matching edit screen from each result.",
  "applicationCategory": "WordPress Plugin",
  "operatingSystem": "WordPress 6.0+",
  "dateModified": dateModified
};

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "WEUX Content Finder",
  "url": siteUrl,
  "description": "WEUX Content Finder is a WordPress plugin that finds where content is managed across posts, pages, custom post types, templates, patterns, navigation, Elementor data, and supported ACF fields.",
  "downloadUrl": wordpressPluginUrl,
  "operatingSystem": "WordPress 6.0+",
  "applicationCategory": "WordPress Plugin",
  "applicationSubCategory": "Content search and replacement",
  "dateModified": dateModified,
  "featureList": [
    "Search posts, pages, and custom post types.",
    "Search block templates, template parts, synced patterns, navigation menus, and block theme files.",
    "Search Elementor page data and open Elementor edit links where available.",
    "Show ACF match counts in Free.",
    "Add preview-first Search and Replace in Pro.",
    "Review before and after snippets before changing content.",
    "Selectively replace confirmed matches.",
    "Undo completed replacement batches.",
    "Search and replace supported text-like ACF fields in Pro."
  ],
  "author": {
    "@type": "Organization",
    "name": "WEUX Studio",
    "url": studioUrl
  },
  "publisher": {
    "@type": "Organization",
    "name": "WEUX Studio",
    "url": studioUrl
  },
  "sameAs": [
    wordpressPluginUrl,
    studioUrl
  ],
  "offers": [
    { "@type": "Offer", "name": "Free", "price": "0", "priceCurrency": "EUR", "priceValidUntil": "2030-12-31", "url": wordpressPluginUrl },
    { "@type": "Offer", "name": "Single Site", "price": "39", "priceCurrency": "EUR", "priceValidUntil": "2030-12-31", "url": "https://contentfinderwp.com/#comparison" },
    { "@type": "Offer", "name": "5 Sites", "price": "79", "priceCurrency": "EUR", "priceValidUntil": "2030-12-31", "url": "https://contentfinderwp.com/#comparison" },
    { "@type": "Offer", "name": "Unlimited", "price": "149", "priceCurrency": "EUR", "priceValidUntil": "2030-12-31", "url": "https://contentfinderwp.com/#comparison" }
  ]
};

---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalHref} />
    {robots && <meta name="robots" content={robots} />}

    <!-- Icons & Favicons -->
    <link rel="icon" href={`${baseUrl}favicon.ico`} sizes="any" />
    <link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
    <link rel="icon" type="image/png" sizes="32x32" href={`${baseUrl}favicon-32x32.png`} />
    <link rel="icon" type="image/png" sizes="16x16" href={`${baseUrl}favicon-16x16.png`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`${baseUrl}apple-touch-icon.png`} />
    <link rel="manifest" href={`${baseUrl}site.webmanifest`} />
    <link rel="mask-icon" href={`${baseUrl}safari-pinned-tab.svg`} color="#2563EB" />
    <meta name="msapplication-TileColor" content="#2563EB" />
    <meta name="msapplication-TileImage" content={`${baseUrl}mstile-150x150.png`} />
    <meta name="theme-color" content="#2563EB" />

    <!-- Fonts -->
    <!-- Self-hosted via global.css -->

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalHref} />
    <meta property="og:title" content={socialMetaTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`https://contentfinderwp.com${image}`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={socialMetaTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`https://contentfinderwp.com${image}`} />

    <!-- Structured Data: WebSite -->
    {includeProductSchema && <script type="application/ld+json" data-schema="website" set:html={JSON.stringify(webSiteSchema)} />}

    <!-- Structured Data: SoftwareApplication -->
    {includeProductSchema && <script type="application/ld+json" data-schema="software" set:html={JSON.stringify(softwareSchema)} />}

    <!-- Matomo -->
    <script is:inline>
      var _paq = window._paq = window._paq || [];
      _paq.push(['trackPageView']);
      _paq.push(['enableLinkTracking']);
      (function() {
        var u = '//analyse.marcweidemueller.de/';
        _paq.push(['setTrackerUrl', u + 'matomo.php']);
        _paq.push(['setSiteId', '2']);
        var d = document;
        var g = d.createElement('script');
        var s = d.getElementsByTagName('script')[0];
        g.async = true;
        g.src = u + 'matomo.js';
        s.parentNode.insertBefore(g, s);
      })();
    </script>
    <!-- End Matomo Code -->
  </head>
  <body class="font-sans text-gray-900 antialiased bg-white">
    <slot />
    <script>
      document.querySelectorAll('.protected-contact[data-contact-value]').forEach((item) => {
        const encoded = item.getAttribute('data-contact-value');
        const kind = item.getAttribute('data-contact-kind');
        if (!encoded) return;

        try {
          const value = atob(encoded);
          item.textContent = value;

          if (item instanceof HTMLAnchorElement && kind === 'email') {
            item.href = `mailto:${value}`;
          }

          if (item instanceof HTMLAnchorElement && kind === 'phone') {
            item.href = `tel:${value.replace(/\s+/g, '')}`;
          }
        } catch {
          item.textContent = 'Contact details unavailable';
        }
      });
    </script>
  </body>
</html>
