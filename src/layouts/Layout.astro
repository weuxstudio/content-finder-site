---
import '../styles/global.css';
interface Props {
  title?: string;
  description?: string;
}
const { title = 'Content Finder – Stop hunting. Start editing.', description = 'Find any text across WordPress FSE layers and jump straight to the edit screen.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet" />
  </head>
  <body class="font-sans text-gray-900 antialiased bg-white">
    <header class="border-b border-gray-100">
      <div class="mx-auto max-w-6xl px-6 flex items-center justify-between h-16">
        <a href="/" class="flex items-center gap-2 text-lg font-semibold tracking-tight shrink-0">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-500 shrink-0"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          <span class="hidden sm:inline">Content Finder</span>
        </a>
        <nav class="flex items-center gap-2 sm:gap-8 text-sm font-medium text-gray-600">
          <a href="#features" class="hover:text-gray-900 transition-colors px-2 py-1">Features</a>
          <a href="#pricing" class="hover:text-gray-900 transition-colors px-2 py-1">Pricing</a>
          <a href="#docs" class="hidden sm:inline hover:text-gray-900 transition-colors">Docs</a>
          <a href="https://wordpress.org/plugins/content-finder" class="inline-flex items-center gap-1.5 rounded-full bg-gray-900 px-3 sm:px-4 py-2 text-xs sm:text-sm font-medium text-white hover:bg-gray-800 transition-colors shrink-0">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            <span class="hidden sm:inline">Download</span>
          </a>
        </nav>
      </div>
    </header>

    <slot />

    <footer class="border-t border-gray-100">
      <div class="mx-auto max-w-6xl px-6 py-8 sm:py-12 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-gray-500">
        <span>&copy; {new Date().getFullYear()} <a href="https://weux.studio" class="hover:text-gray-900 transition-colors">WEUX Studio</a></span>
        <div class="flex items-center gap-6">
          <a href="https://github.com/weuxstudio/content-finder" class="hover:text-gray-900 transition-colors">GitHub</a>
          <a href="https://wordpress.org/plugins/content-finder" class="hover:text-gray-900 transition-colors">WP.org</a>
        </div>
      </div>
    </footer>
  </body>
</html>
