---
import Layout from '../layouts/Layout.astro';
import logoUrl from '../../branding/Logo-contentfinder.svg';

const baseUrl = import.meta.env.BASE_URL;
const logoSrc = typeof logoUrl === 'string' ? logoUrl : logoUrl.src;
---

<Layout title="Content Finder | Coming Soon" description="Content Finder is coming soon. Find WordPress content across templates, template parts, patterns, navigation, and posts.">
  <main class="cs-page overflow-hidden text-[#17181d]">
    <section class="cs-hero relative isolate">
      <div class="cs-bg absolute inset-0 -z-20"></div>
      <div class="absolute inset-x-0 top-0 -z-10 h-px bg-gradient-to-r from-transparent via-blue-500/30 to-transparent"></div>

      <div class="cs-shell">
        <div class="cs-enter cs-copy">
          <img src={logoSrc} alt="" class="cs-mobile-mark" />
          <a href={baseUrl} class="inline-flex items-center gap-3 text-sm font-semibold text-slate-800 transition hover:text-blue-600" aria-label="Back to Content Finder landing page">
            <img src={logoSrc} alt="" class="h-9 w-9 rounded-xl" />
            <span>Content Finder</span>
          </a>

          <div class="cs-heading">
            <p class="mb-5 text-sm font-semibold text-blue-600">Launching soon</p>
            <h1 class="cs-title">
              Find WordPress content faster.
            </h1>
            <p class="cs-subcopy">
              A clean search layer for posts, templates, patterns, navigation, Elementor data, and supported ACF fields.
            </p>
          </div>

          <form id="notify-form" class="cs-form" novalidate>
            <label class="sr-only" for="email">Email address</label>
            <input id="email" name="email" type="email" inputmode="email" autocomplete="email" required placeholder="you@domain.com" aria-describedby="notify-feedback" class="cs-input" />
            <button id="notify-submit" type="submit" class="cs-submit inline-flex min-h-12 items-center justify-center rounded-full bg-blue-600 text-sm font-semibold text-white shadow-lg shadow-blue-600/20 transition hover:-translate-y-0.5 hover:bg-blue-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-blue-500 disabled:cursor-not-allowed disabled:opacity-70">
              Notify me
            </button>
          </form>
          <p id="notify-feedback" class="notify-feedback mt-4 hidden max-w-2xl rounded-2xl px-4 py-3 text-sm font-medium" aria-live="polite"></p>

          <div class="cs-meta flex flex-wrap gap-x-8 gap-y-3 text-sm font-medium text-slate-500">
            <span class="inline-flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-blue-600"></span>Private beta</span>
            <span>Runs inside WordPress</span>
            <span>No external search service</span>
          </div>
        </div>

        <div class="cs-enter cs-enter-delay cs-stage">
          <img src={logoSrc} alt="" class="cs-logo-orbit" />

          <div class="cs-chip">
            WordPress FSE
          </div>
        </div>
      </div>
    </section>
  </main>

  <script>
    const form = document.querySelector('#notify-form');
    const emailInput = document.querySelector('#email');
    const feedback = document.querySelector('#notify-feedback');
    const submitButton = document.querySelector('#notify-submit');
    const emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/i;

    const setFeedback = (type, message) => {
      if (!feedback) return;

      feedback.textContent = message;
      feedback.className = `notify-feedback mt-4 max-w-2xl rounded-2xl px-4 py-3 text-sm font-medium is-${type}`;
    };

    const setLoading = (isLoading) => {
      if (!submitButton) return;

      submitButton.disabled = isLoading;
      submitButton.textContent = isLoading ? 'Saving...' : 'Notify me';
    };

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();

      const email = emailInput instanceof HTMLInputElement ? emailInput.value.trim().toLowerCase() : '';

      if (!emailPattern.test(email)) {
        emailInput?.setAttribute('aria-invalid', 'true');
        setFeedback('error', 'Please enter a valid email address.');
        emailInput?.focus();
        return;
      }

      emailInput?.setAttribute('aria-invalid', 'false');
      setFeedback('loading', 'Adding you to the launch list...');
      setLoading(true);

      try {
        const response = await fetch('/api/notify', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });
        const result = await response.json().catch(() => ({}));

        if (!response.ok) {
          throw new Error(result.message || 'Something went wrong. Please try again.');
        }

        form.reset();
        setFeedback('success', result.message || 'You are on the list. We will let you know when Content Finder launches.');
      } catch (error) {
        setFeedback('error', error instanceof Error ? error.message : 'Something went wrong. Please try again.');
      } finally {
        setLoading(false);
      }
    });
  </script>
</Layout>
