---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Imprint | WEUX Content Finder"
  description="Legal information about WEUX Content Finder: contact details, responsible person, and legal disclosure according to German law."
  canonicalPath="/imprint/"
  robots="noindex,follow"
>
  <nav class="nav">
    <div class="wrap nav-inner">
      <a href="/" class="nav-logo" aria-label="WEUX Content Finder home">
        <img class="nav-logo-mark" src="/header-logo-mark.svg" alt="" />
        <img class="nav-logo-wordmark" src="/header-logo-wordmark.svg" alt="WEUX Content Finder" />
      </a>
      <div class="nav-menu">
        <a href="/#problem" class="nav-link">Problem</a>
        <a href="/#coverage" class="nav-link">Coverage</a>
        <a href="/#pro" class="nav-link">Pro</a>
        <a href="/#comparison" class="nav-link">Free vs Pro</a>
        <a href="/#usecases" class="nav-link">Use Cases</a>
      </div>
      <div class="nav-cta">
        <a href="/#comparison" class="btn btn-outline">Compare</a>
        <a href="https://wordpress.org/plugins/weux-content-finder/" class="btn btn-dark" target="_blank" rel="noopener noreferrer">Get Free</a>
      </div>
    </div>
  </nav>

  <main class="legal-page">
    <section class="legal-hero">
      <div class="wrap legal-hero-inner">
        <a href="/" class="legal-back">Back to home</a>
        <span class="eyebrow">Legal</span>
        <h1 class="h-section">Imprint</h1>
        <p class="body-l">Information according to Section 5 DDG for WEUX Content Finder.</p>
      </div>
    </section>

    <section class="legal-body">
      <div class="wrap legal-grid">
        <aside class="legal-side">
          <p>Operator details, contact information, and mandatory German legal disclosure.</p>
        </aside>
        <div class="legal-content">
          <section>
            <h2>Responsible Operator</h2>
            <p>
              <strong>WEUX Studio</strong><br />
              Marc Weidemüller<br />
              Elisabeth-Flügge-Straße 6b<br />
              22337 Hamburg<br />
              Germany
            </p>
          </section>

          <section>
            <h2>Contact</h2>
            <p>
              Email: <a href="#" class="protected-contact" data-contact-kind="email" data-contact-value="aGVsbG9Ad2V1eC5zdHVkaW8=">Reveal email</a><br />
              Phone: <span class="protected-contact" data-contact-kind="phone" data-contact-value="KzQ5IDE3OCA2NTU4NjIz">Reveal phone</span>
            </p>
          </section>

          <section>
            <h2>VAT</h2>
            <p>Sales tax is not shown in accordance with the small business regulation under Section 19 UStG.</p>
          </section>

          <section>
            <h2>Responsible for Editorial Content</h2>
            <p>Marc Weidemüller, Elisabeth-Flügge-Straße 6b, 22337 Hamburg, Germany</p>
          </section>

          <section>
            <h2>Dispute Resolution</h2>
            <p>
              The European Commission provides a platform for online dispute resolution:<br />
              <a href="https://ec.europa.eu/consumers/odr/" target="_blank" rel="noopener noreferrer">https://ec.europa.eu/consumers/odr/</a>
            </p>
            <p>We are not willing or obliged to participate in dispute resolution proceedings before a consumer arbitration board.</p>
          </section>
        </div>
      </div>
    </section>
  </main>

  <div class="cta-footer legal-footer">
    <footer>
      <div class="footer-shell">
        <div class="wrap">
          <div class="footer-inner">
            <div class="footer-brand">
              <a href="/" class="footer-logo" aria-label="WEUX Content Finder home">
                <img src="/footer-logo.svg" alt="WEUX Content Finder" />
              </a>
              <p>The WordPress content search tool for production sites. Find where content is managed and open the right editor.</p>
            </div>
            <div class="footer-cols">
              <div><h4>Product</h4><ul><li><a href="/#coverage">Search Coverage</a></li><li><a href="/#pro">Pro Features</a></li><li><a href="/#comparison">Free vs Pro</a></li><li><a href="/#usecases">Use Cases</a></li></ul></div>
              <div><h4>Resources</h4><ul><li><a href="/#trust">Trust & Safety</a></li><li><a href="/#faq">FAQs</a></li><li><a href="/#problem">The Problem</a></li><li><a href="/#workflow">How It Works</a></li></ul></div>
              <div><h4>Get Started</h4><ul><li><a href="https://wordpress.org/plugins/weux-content-finder/" target="_blank" rel="noopener noreferrer">Download Free</a></li><li><a href="/#download">Upgrade to Pro</a></li><li><a href="https://wordpress.org/plugins/weux-content-finder/" target="_blank" rel="noopener noreferrer">WordPress.org</a></li></ul></div>
            </div>
          </div>
          <div class="footer-bottom">
            <span class="footer-copyright">© 2026 WEUX Content Finder. Built for WordPress editing screens, not database migrations. <span class="footer-legal-links"><a href="/imprint/">Imprint</a><a href="/privacy-policy/">Privacy Policy</a></span></span>
            <span class="footer-credit-text">Crafted for WordPress teams by <a href="https://weux.studio/" target="_blank" rel="noopener noreferrer" class="footer-credit"><svg width="64" height="46" viewBox="0 0 64 46" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path fill-rule="evenodd" clip-rule="evenodd" d="M29.2872 11.4831L23.832 1.70528L15.7996 1.70526L25.1425 18.4519L29.2872 11.4831Z" fill="#F3D054"/><path fill-rule="evenodd" clip-rule="evenodd" d="M28.8769 10.6603L34.332 0.882529L42.3645 0.882502L33.0215 17.6291L28.8769 10.6603Z" fill="#F3D054"/><path fill-rule="evenodd" clip-rule="evenodd" d="M29.0598 24.7318L21.8841 37.5938L0.100727 0.967424L0.211486 0.882745L8.23723 0.882885L21.7021 23.5224L24.9152 17.7632L28.8314 10.5827L36.5273 23.5224L49.1583 0.882787L57.1907 0.88276L36.7093 37.5938L29.0598 24.7318Z" fill="#E8E7E7"/></svg>weux.studio</a></span>
          </div>
        </div>
      </div>
    </footer>
  </div>
</Layout>
