---
import Layout from '../layouts/Layout.astro';

const baseUrl = import.meta.env.BASE_URL;
---

<Layout title="Content Finder - Coming Soon" description="Content Finder is coming soon. Find and edit WordPress content across every Full Site Editing layer faster.">
  <main class="min-h-[calc(100vh-5rem)] overflow-hidden bg-white text-slate-950">
    <section class="relative isolate flex min-h-[calc(100vh-5rem)] items-center">
      <div class="soft-grid absolute inset-0 -z-20"></div>
      <div class="ambient-sweep absolute inset-x-0 top-0 -z-10 h-72"></div>
      <div class="absolute left-1/2 top-16 -z-10 h-72 w-72 -translate-x-1/2 rounded-full bg-cyan-200/20 blur-3xl"></div>

      <div class="mx-auto grid w-full max-w-6xl items-center gap-14 px-6 py-16 sm:py-20 lg:grid-cols-[1.04fr_0.96fr] lg:py-24">
        <div class="reveal max-w-2xl">
          <a href={baseUrl} class="group inline-flex items-center gap-3" aria-label="Content Finder home">
            <span class="logo-mark relative flex h-14 w-14 items-center justify-center rounded-[1.15rem] bg-slate-950 text-white shadow-2xl shadow-cyan-500/20">
              <svg viewBox="0 0 64 64" aria-hidden="true" class="h-9 w-9">
                <path d="M16 18.5C16 15.5 18.5 13 21.5 13h17C41.5 13 44 15.5 44 18.5v7.75" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" />
                <path d="M21 26.5C21 23.5 23.5 21 26.5 21h17C46.5 21 49 23.5 49 26.5v7" fill="none" stroke="#5eead4" stroke-width="4" stroke-linecap="round" />
                <circle cx="30.5" cy="34.5" r="12.5" fill="none" stroke="currentColor" stroke-width="4.5" />
                <path d="m40.5 44.5 8.5 8.5" stroke="#38bdf8" stroke-width="5" stroke-linecap="round" />
              </svg>
              <span class="logo-shine absolute inset-0 rounded-[1.15rem]"></span>
            </span>
            <span class="flex flex-col leading-none">
              <span class="text-xl font-semibold tracking-tight text-slate-950">Content Finder</span>
              <span class="mt-1 text-xs font-medium uppercase tracking-[0.28em] text-cyan-700">WordPress FSE</span>
            </span>
          </a>

          <h1 class="mt-12 max-w-3xl text-5xl font-semibold tracking-tight text-slate-950 sm:text-6xl lg:text-7xl">
            Coming Soon
          </h1>
          <p class="mt-6 max-w-xl text-lg leading-8 text-slate-600">
            The fastest way to find hidden WordPress content across templates, template parts, patterns, navigation, and posts is almost ready.
          </p>

          <form id="notify-form" class="mt-9 flex w-full max-w-xl flex-col gap-3 rounded-[1.4rem] border border-slate-200 bg-white/85 p-2 shadow-2xl shadow-slate-200/70 backdrop-blur sm:flex-row" novalidate>
            <label class="sr-only" for="email">Email address</label>
            <input id="email" name="email" type="email" inputmode="email" autocomplete="email" required placeholder="your@email.com" aria-describedby="notify-feedback" class="min-h-12 flex-1 rounded-2xl border-0 bg-transparent px-4 text-sm font-medium text-slate-900 outline-none placeholder:text-slate-400 focus-visible:ring-2 focus-visible:ring-cyan-300" />
            <button id="notify-submit" type="submit" class="inline-flex min-h-12 items-center justify-center gap-2 rounded-2xl bg-slate-950 px-5 text-sm font-semibold text-white transition hover:-translate-y-0.5 hover:bg-slate-800 hover:shadow-lg hover:shadow-cyan-500/20 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cyan-500 disabled:cursor-not-allowed disabled:opacity-70">
              Notify me
              <svg viewBox="0 0 24 24" aria-hidden="true" class="h-4 w-4">
                <path d="M5 12h14m-6-6 6 6-6 6" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </button>
          </form>
          <p id="notify-feedback" class="notify-feedback mt-3 hidden max-w-xl rounded-2xl px-4 py-3 text-sm font-medium" aria-live="polite"></p>

          <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-3 text-sm text-slate-500">
            <span class="inline-flex items-center gap-2">
              <span class="h-2 w-2 rounded-full bg-emerald-400"></span>
              Private beta in progress
            </span>
          </div>
        </div>

        <div class="reveal reveal-delay relative mx-auto w-full max-w-[31rem] lg:mr-0">
          <div class="preview-float relative rounded-[2rem] border border-slate-200 bg-white p-4 shadow-2xl shadow-slate-200/80">
            <div class="rounded-[1.45rem] border border-slate-100 bg-slate-50/80 p-4">
              <div class="flex items-center justify-between border-b border-slate-200 pb-4">
                <div class="flex items-center gap-2">
                  <span class="h-3 w-3 rounded-full bg-rose-300"></span>
                  <span class="h-3 w-3 rounded-full bg-amber-300"></span>
                  <span class="h-3 w-3 rounded-full bg-emerald-300"></span>
                </div>
                <span class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">Search all layers</span>
              </div>

              <div class="mt-5 rounded-2xl border border-slate-200 bg-white px-4 py-3 shadow-sm">
                <div class="flex items-center gap-3">
                  <svg viewBox="0 0 24 24" aria-hidden="true" class="h-5 w-5 text-cyan-600">
                    <circle cx="11" cy="11" r="7" fill="none" stroke="currentColor" stroke-width="2.2" />
                    <path d="m16.5 16.5 4 4" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" />
                  </svg>
                  <span class="text-sm font-medium text-slate-900">footer phone number</span>
                </div>
              </div>

              <div class="mt-5 space-y-3">
                {[
                  ['Template Part', 'Footer', '3 matches'],
                  ['Navigation', 'Primary menu', '1 match'],
                  ['Pattern', 'Contact banner', '2 matches'],
                ].map(([type, title, count]) => (
                  <div class="result-row flex items-center justify-between rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
                    <div>
                      <p class="text-sm font-semibold text-slate-950">{title}</p>
                      <p class="mt-1 text-xs font-medium uppercase tracking-[0.18em] text-cyan-700">{type}</p>
                    </div>
                    <span class="rounded-full bg-cyan-50 px-3 py-1 text-xs font-semibold text-cyan-700">{count}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <script>
    const form = document.querySelector('#notify-form');
    const emailInput = document.querySelector('#email');
    const feedback = document.querySelector('#notify-feedback');
    const submitButton = document.querySelector('#notify-submit');
    const emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/i;

    const setFeedback = (type, message) => {
      if (!feedback) return;

      feedback.textContent = message;
      feedback.className = `notify-feedback mt-3 max-w-xl rounded-2xl px-4 py-3 text-sm font-medium is-${type}`;
    };

    const setLoading = (isLoading) => {
      if (!submitButton) return;

      submitButton.disabled = isLoading;
      submitButton.innerHTML = isLoading
        ? '<span class="notify-spinner" aria-hidden="true"></span> Saving...'
        : 'Notify me <svg viewBox="0 0 24 24" aria-hidden="true" class="h-4 w-4"><path d="M5 12h14m-6-6 6 6-6 6" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" /></svg>';
    };

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();

      const email = emailInput instanceof HTMLInputElement ? emailInput.value.trim().toLowerCase() : '';

      if (!emailPattern.test(email)) {
        emailInput?.setAttribute('aria-invalid', 'true');
        setFeedback('error', 'Please enter a valid email address.');
        emailInput?.focus();
        return;
      }

      emailInput?.setAttribute('aria-invalid', 'false');
      setFeedback('loading', 'Adding you to the launch list...');
      setLoading(true);

      try {
        const response = await fetch('/api/notify', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });
        const result = await response.json().catch(() => ({}));

        if (!response.ok) {
          throw new Error(result.message || 'Something went wrong. Please try again.');
        }

        form.reset();
        setFeedback('success', result.message || 'You are on the list. We will let you know when Content Finder launches.');
      } catch (error) {
        setFeedback('error', error instanceof Error ? error.message : 'Something went wrong. Please try again.');
      } finally {
        setLoading(false);
      }
    });
  </script>
</Layout>
