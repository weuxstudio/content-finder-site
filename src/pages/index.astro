---
import Layout from '../layouts/Layout.astro';
---

<Layout title="WEUX Content Finder - Find and fix WordPress content faster" description="Search across posts, pages, custom post types, templates, patterns, navigation, Elementor data, and ACF fields from one WordPress admin screen.">
  <nav class="nav">
    <div class="wrap nav-inner">
      <a href="#" class="nav-logo">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
        <span>WEUX Content Finder</span>
      </a>
      <div class="nav-menu">
        <a href="#problem" class="nav-link">Problem</a>
        <a href="#coverage" class="nav-link">Coverage</a>
        <a href="#pro" class="nav-link">Pro</a>
        <a href="#comparison" class="nav-link">Free vs Pro</a>
        <a href="#usecases" class="nav-link">Use Cases</a>
      </div>
      <div class="nav-cta">
        <a href="#comparison" class="btn btn-outline">Compare</a>
        <a href="#download" class="btn btn-dark">Get Free</a>
      </div>
      <button class="mobile-toggle" id="mobileToggle" type="button" aria-label="Toggle navigation">☰</button>
    </div>
  </nav>

  <section class="hero round-bottom bg-white" id="hero">
    <div class="wrap">
      <div class="hero-grid">
        <div class="hero-inner fade-up">
          <h1 class="h-hero"><span class="text-blue">Find</span> and <span class="text-blue">fix</span><br />WordPress <span class="text-blue">content</span><br />faster.</h1>
          <p class="hero-sub">Search across posts, pages, custom post types, templates, template parts, navigation, synced patterns, block theme files, Elementor data, and supported ACF fields — from one WordPress admin screen. Jump straight to the right editor, or use Pro to preview, replace, and undo changes safely.</p>
          <div class="hero-ctas">
            <a href="#download" class="btn btn-blue btn-lg">Download Free Plugin →</a>
            <a href="#comparison" class="btn btn-outline btn-lg">Compare Free and Pro</a>
          </div>
          <div class="hero-meta">
            <span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M20 6 9 17l-5-5"/></svg> Runs inside WordPress</span>
            <span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M20 6 9 17l-5-5"/></svg> No external service</span>
            <span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M20 6 9 17l-5-5"/></svg> Editor-focused results</span>
          </div>
        </div>

        <div class="mockup-wrap fade-up" style="animation-delay:.15s">
          <div class="mockup">
            <div class="mockup-bar">
              <span class="d r"></span><span class="d y"></span><span class="d g"></span>
              <span class="url">wp-admin → Content Finder</span>
            </div>
            <div class="mockup-body">
              <div class="mockup-search">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
                <input type="text" value="old brand name" readonly />
                <span class="kbd">⌘ K</span>
              </div>
              <div class="mockup-filters">
                <span class="mf active">All (14)</span><span class="mf">Pages (5)</span><span class="mf">Templates (3)</span><span class="mf">Patterns (2)</span><span class="mf">Elementor (3)</span><span class="mf">ACF (1)</span>
              </div>
              <div class="mockup-results">
                <div class="mr"><span class="type page">Page</span><span class="snip">About Us — <mark>old brand name</mark> is a creative agency…</span><span class="link">Edit →</span></div>
                <div class="mr"><span class="type tpl">Template</span><span class="snip">header.html — <mark>old brand name</mark> footer text</span><span class="link">Site Editor →</span></div>
                <div class="mr"><span class="type pat">Pattern</span><span class="snip">cta-section — <mark>old brand name</mark> call to action</span><span class="link">Edit →</span></div>
                <div class="mr"><span class="type el">Elementor</span><span class="snip">Homepage — <mark>old brand name</mark> hero heading</span><span class="link">Edit in Elementor →</span></div>
                <div class="mr"><span class="type menu">Menu</span><span class="snip">Footer Menu — <mark>old brand name</mark> link label</span><span class="link">Edit →</span></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="problem">
    <div class="wrap problem-grid">
      <div>
        <div class="reveal" style="margin-bottom:8px"><span class="eyebrow">The Problem</span></div>
        <h2 class="h-section reveal" style="margin-bottom:20px">WordPress content is<br />scattered everywhere.</h2>
        <p class="body-l reveal" style="max-width:560px;margin-bottom:0">Teams waste time clicking through editors, guessing where copy lives, or using database-level tools that don't point to the actual editing surface.</p>

        <div class="problem-narrative reveal">
          <p><strong>WEUX Content Finder is not a generic database search tool.</strong> It is an editor-focused content locator and safe replacement workflow that searches the content layers WordPress teams actually edit — and opens the best available editor for each result.</p>
          <ul class="problem-list">
            <li>Shows result type, match count, snippet, status, and modified date</li>
            <li>Opens the best available editor — Site Editor, Elementor, or standard editors</li>
            <li>Keeps free search local inside WordPress; no external service required</li>
            <li>Separates discovery from mutation: Free finds, Pro changes with preview and undo</li>
          </ul>
        </div>
      </div>

      <div class="problem-map reveal">
        <div class="problem-layer-list">
          <div class="problem-layer">
            <svg class="problem-layer-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M8 13h8"/><path d="M8 17h5"/></svg>
            <p>Posts & Pages</p>
          </div>
          <div class="problem-layer">
            <svg class="problem-layer-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M4 7h16"/><path d="M4 12h16"/><path d="M4 17h16"/><path d="M8 3v18"/><path d="M16 3v18"/></svg>
            <p>Custom Post Types</p>
          </div>
          <div class="problem-layer">
            <svg class="problem-layer-icon" viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
            <p>Block Templates</p>
          </div>
          <div class="problem-layer">
            <svg class="problem-layer-icon" viewBox="0 0 24 24" aria-hidden="true"><rect x="4" y="4" width="6" height="6" rx="1"/><rect x="14" y="4" width="6" height="6" rx="1"/><rect x="4" y="14" width="6" height="6" rx="1"/><rect x="14" y="14" width="6" height="6" rx="1"/></svg>
            <p>Template Parts</p>
          </div>
          <div class="problem-layer">
            <svg class="problem-layer-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M7 7h10v10H7z"/><path d="M4 4h10"/><path d="M10 20h10"/><path d="M4 4v10"/><path d="M20 10v10"/></svg>
            <p>Synced Patterns</p>
          </div>
          <div class="problem-layer">
            <svg class="problem-layer-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M4 6h16"/><path d="M4 12h10"/><path d="M4 18h13"/><circle cx="18" cy="12" r="2"/><circle cx="20" cy="18" r="2"/></svg>
            <p>Navigation Menus</p>
          </div>
          <div class="problem-layer">
            <svg class="problem-layer-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M8 3 4 7l4 4"/><path d="m16 3 4 4-4 4"/><path d="M4 17h16"/><path d="M8 21h8"/></svg>
            <p>Block Theme Files</p>
          </div>
          <div class="problem-layer">
            <svg class="problem-layer-icon" viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="3"/><path d="M7 9h.01"/><path d="M10 9h.01"/><path d="M13 9h.01"/><path d="M7 14h10"/></svg>
            <p>Elementor Metadata</p>
          </div>
          <div class="problem-layer">
            <svg class="problem-layer-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M4 5h16"/><path d="M4 12h16"/><path d="M4 19h16"/><circle cx="8" cy="5" r="2"/><circle cx="15" cy="12" r="2"/><circle cx="10" cy="19" r="2"/></svg>
            <p>ACF Fields</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-white round-top round-bottom" id="coverage">
    <div class="wrap">
      <div style="text-align:center;margin-bottom:48px" class="reveal">
        <span class="eyebrow">Search Coverage</span>
        <h2 class="h-section" style="margin-top:8px;margin-bottom:12px">Search the places content<br />actually lives.</h2>
        <p class="body-l" style="max-width:540px;margin:0 auto">One search across every layer WordPress teams edit — with direct links to the right editor for each result.</p>
      </div>
      <div class="coverage-list">
        <div class="cov-item reveal">
          <svg class="cov-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M8 13h8"/><path d="M8 17h5"/></svg>
          <div><h3>Posts & Pages</h3><p>Search all post and page content with highlighted match snippets.</p></div>
        </div>
        <div class="cov-item reveal">
          <svg class="cov-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 7h16"/><path d="M4 12h16"/><path d="M4 17h16"/><path d="M8 3v18"/><path d="M16 3v18"/></svg>
          <div><h3>Custom Post Types</h3><p>Search all public custom post types automatically.</p></div>
        </div>
        <div class="cov-item reveal">
          <svg class="cov-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
          <div><h3>Block Templates</h3><p>Search block templates and template parts. Open in Site Editor where possible.</p></div>
        </div>
        <div class="cov-item reveal">
          <svg class="cov-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="4" y="4" width="6" height="6" rx="1"/><rect x="14" y="4" width="6" height="6" rx="1"/><rect x="4" y="14" width="6" height="6" rx="1"/><rect x="14" y="14" width="6" height="6" rx="1"/></svg>
          <div><h3>Synced Patterns</h3><p>Search synced reusable patterns across the site.</p></div>
        </div>
        <div class="cov-item reveal">
          <svg class="cov-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 6h16"/><path d="M4 12h10"/><path d="M4 18h13"/><circle cx="18" cy="12" r="2"/><circle cx="20" cy="18" r="2"/></svg>
          <div><h3>Navigation Menus</h3><p>Search block navigation and classic menu items where the theme supports them.</p></div>
        </div>
        <div class="cov-item reveal">
          <svg class="cov-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 3 4 7l4 4"/><path d="m16 3 4 4-4 4"/><path d="M4 17h16"/><path d="M8 21h8"/></svg>
          <div><h3>Block Theme Files</h3><p>Search templates/*.html, parts/*.html, and referenced patterns/*.php.</p></div>
        </div>
        <div class="cov-item reveal">
          <svg class="cov-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2 3 7l9 5 9-5-9-5z"/><path d="m3 12 9 5 9-5"/><path d="m3 17 9 5 9-5"/></svg>
          <div><h3>Elementor Data</h3><p>Search Elementor page data. Get Edit in Elementor links where detected.</p></div>
        </div>
        <div class="cov-item reveal">
          <svg class="cov-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.6 13.4 13.4 20.6a2 2 0 0 1-2.8 0l-7.2-7.2a2 2 0 0 1 0-2.8l7.2-7.2a2 2 0 0 1 2.8 0l7.2 7.2a2 2 0 0 1 0 2.8z"/><path d="M7 17 17 7"/></svg>
          <div><h3>ACF Teaser</h3><p>Free shows a count-only teaser. Pro unlocks full supported-field search and replace.</p></div>
        </div>
      </div>
      <p style="text-align:center;margin-top:32px;font-size:.9375rem;color:var(--ink-light)" class="reveal">Results don't just show matches — they point you to the best available editor target, including Site Editor links for block themes and Elementor edit links where possible.</p>
    </div>
  </section>

  <section class="section support-section" id="builder-acf">
    <div class="wrap support-grid">
      <div class="reveal">
        <span class="eyebrow">ACF & Builder Support</span>
        <h2 class="h-section" style="margin-top:8px;margin-bottom:16px">Builder-aware search,<br />careful field handling.</h2>
        <p class="body-l" style="max-width:520px">Elementor support is included in Free where detected. ACF stays careful by default: Free shows matching field counts, while Pro unlocks supported text-like field search and replace.</p>
      </div>
      <div class="support-list reveal">
        <div class="support-item">
          <svg class="support-icon" viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="3"/><path d="M7 9h.01"/><path d="M10 9h.01"/><path d="M13 9h.01"/><path d="M7 14h10"/></svg>
          <div><h3>Elementor in Free</h3><p>Search Elementor page data and open Edit in Elementor links where safe editor targets are detected.</p></div>
        </div>
        <div class="support-item">
          <svg class="support-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M4 5h16"/><path d="M4 12h16"/><path d="M4 19h16"/><circle cx="8" cy="5" r="2"/><circle cx="15" cy="12" r="2"/><circle cx="10" cy="19" r="2"/></svg>
          <div><h3>ACF in Free</h3><p>Show a count-only teaser when matching ACF fields exist, without exposing field values.</p></div>
        </div>
        <div class="support-item">
          <svg class="support-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M4 7h7"/><path d="M4 12h10"/><path d="M4 17h7"/><path d="M17 8l3 3-3 3"/><path d="M20 11h-5"/></svg>
          <div><h3>ACF in Pro</h3><p>Search and replace across supported text-like ACF fields with preview, selection, and undo.</p></div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="workflow">
    <div class="wrap">
      <div style="text-align:center;margin-bottom:48px" class="reveal">
        <span class="eyebrow">How It Works</span>
        <h2 class="h-section" style="margin-top:8px">Search, filter, inspect,<br />open editor.</h2>
      </div>
      <div class="flow reveal">
        <div class="flow-step">
          <div class="num"><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m16.5 16.5 4 4"/></svg></div>
          <h3>Search</h3><p>Type any text. Search runs locally inside WordPress.</p>
        </div>
        <span class="flow-arrow">→</span>
        <div class="flow-step">
          <div class="num"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 6h16"/><path d="M7 12h10"/><path d="M10 18h4"/></svg></div>
          <h3>Filter</h3><p>Filter by result type — pages, templates, patterns, Elementor, and more.</p>
        </div>
        <span class="flow-arrow">→</span>
        <div class="flow-step">
          <div class="num"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/></svg></div>
          <h3>Inspect</h3><p>Review match snippets, type, count, status, and modified date.</p>
        </div>
        <span class="flow-arrow">→</span>
        <div class="flow-step">
          <div class="num"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M14 3h7v7"/><path d="M21 3 10 14"/><path d="M11 5H5a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-6"/></svg></div>
          <h3>Open Editor</h3><p>Jump to the right editor — Site Editor, Elementor, or standard editors.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-dark round-top round-bottom" id="pro">
    <div class="wrap">
      <div style="text-align:center;margin-bottom:8px" class="reveal"><span class="eyebrow" style="color:var(--blue-400)">Pro — Fix It at Scale</span></div>
      <h2 class="h-section reveal" style="color:#fff;text-align:center;margin-bottom:16px">Preview-first<br />Search and Replace.</h2>
      <div class="pro-intro reveal"><p>Pro turns discovery into action. Preview replacements, review before/after snippets, choose exactly which items to update, then run the replacement with batch undo available.</p></div>
      <div class="pro-list">
        <div class="pro-item reveal">
          <svg class="pro-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M4 7h7"/><path d="M4 12h10"/><path d="M4 17h7"/><path d="M17 8l3 3-3 3"/><path d="M20 11h-5"/></svg>
          <div><h3><span class="pro-tag">Pro</span>Replacement Preview</h3><p>Review before/after diff snippets before any content is changed. See exactly what will be replaced.</p></div>
        </div>
        <div class="pro-item reveal">
          <svg class="pro-icon" viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="4" width="13" height="13" rx="2"/><path d="m7 10 2 2 4-5"/><path d="m14 14 6 6"/><path d="m20 14-6 6"/></svg>
          <div><h3><span class="pro-tag">Pro</span>Selective Replacement</h3><p>Select all, clear, or choose specific items. Replace confirmed items only — not blind bulk mutation.</p></div>
        </div>
        <div class="pro-item reveal">
          <svg class="pro-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M9 14 4 9l5-5"/><path d="M4 9h10a6 6 0 1 1-4.2 10.2"/></svg>
          <div><h3><span class="pro-tag">Pro</span>Batch Undo</h3><p>Every replace job is stored as a snapshot. Undo a full batch via replace job history if something is off.</p></div>
        </div>
        <div class="pro-item reveal">
          <svg class="pro-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M4 5h16"/><path d="M4 12h16"/><path d="M4 19h16"/><circle cx="8" cy="5" r="2"/><circle cx="15" cy="12" r="2"/><circle cx="10" cy="19" r="2"/></svg>
          <div><h3><span class="pro-tag">Pro</span>ACF Field Replacement</h3><p>Search and replace across supported ACF text-like fields — without exposing field values in Free.</p></div>
        </div>
        <div class="pro-item reveal">
          <svg class="pro-icon" viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="3"/><path d="M7 9h.01"/><path d="M10 9h.01"/><path d="M13 9h.01"/><path d="M7 14h10"/></svg>
          <div><h3><span class="pro-tag">Pro</span>Global Cmd+K Overlay</h3><p>Live search overlay across WordPress admin. Edit links and replace navigation from anywhere. Native Command Palette fallback included.</p></div>
        </div>
        <div class="pro-item reveal">
          <svg class="pro-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M3 12a9 9 0 1 0 3-6.7"/><path d="M3 4v5h5"/><path d="M12 7v5l3 2"/></svg>
          <div><h3><span class="pro-tag">Pro</span>Replace Job History</h3><p>Review recent replace jobs. Sticky review actions for larger replacement sets. Lemon Squeezy license activation built in.</p></div>
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-white round-top round-bottom" id="comparison">
    <div class="wrap">
      <div style="text-align:center;margin-bottom:48px" class="reveal">
        <span class="eyebrow">Free vs Pro</span>
        <h2 class="h-section" style="margin-top:8px;margin-bottom:12px">Choose your plan.</h2>
        <p class="body-l" style="max-width:480px;margin:0 auto">Free finds content. Pro changes it safely with preview, confirmation, and undo.</p>
      </div>

      <div class="pricing-grid">
        <div class="plan-card plan-free reveal">
          <div class="plan-body">
            <div class="plan-name">Free</div>
            <p class="plan-desc">Best for finding where content lives.</p>
            <div class="plan-price"><strong>$0</strong> <span class="per">Free forever</span></div>
            <div class="plan-divider"></div>
            <div class="plan-features">
              {['Search all content layers','Direct editor links','Elementor links where detected','ACF count teaser','No Search and Replace'].map((item) => (
                <div class="plan-feat yes"><span class="check">✓</span><span class="feat-label">{item}</span></div>
              ))}
            </div>
          </div>
          <div class="plan-footer">
            <a href="#download" class="plan-cta plan-cta-outline">Download Free →</a>
            <p style="text-align:center;font-size:.8125rem;color:var(--ink-faint);margin-top:12px">Install from WordPress.org</p>
          </div>
        </div>

        <div class="plan-card plan-pro reveal">
          <div class="plan-body">
            <span class="plan-badge">Pro</span>
            <div class="plan-name">Single Site</div>
            <p class="plan-desc">Best for one production site.</p>
            <div class="plan-price"><strong>€39</strong> <span class="per">per year</span></div>
            <div class="plan-divider"></div>
            <div class="plan-features">
              {['Everything in Free','All Pro features','1 website'].map((item) => (
                <div class="plan-feat yes"><span class="check">✓</span><span class="feat-label">{item}</span></div>
              ))}
            </div>
          </div>
          <div class="plan-footer-dark">
            <a href="#pro" class="plan-cta">Upgrade to Pro →</a>
            <p class="plan-license-note">License via Lemon Squeezy</p>
          </div>
        </div>

        <div class="plan-card plan-pro plan-popular reveal">
          <div class="plan-body">
            <span class="plan-badge">Popular</span>
            <div class="plan-name">5 Sites</div>
            <p class="plan-desc">Best for freelancers and small client portfolios.</p>
            <div class="plan-price"><strong>€79</strong> <span class="per">per year</span></div>
            <div class="plan-divider"></div>
            <div class="plan-features">
              {['Everything in Free','All Pro features','Up to 5 websites'].map((item) => (
                <div class="plan-feat yes"><span class="check">✓</span><span class="feat-label">{item}</span></div>
              ))}
            </div>
          </div>
          <div class="plan-footer-dark">
            <a href="#pro" class="plan-cta">Upgrade to Pro →</a>
            <p class="plan-license-note">License via Lemon Squeezy</p>
          </div>
        </div>

        <div class="plan-card plan-pro reveal">
